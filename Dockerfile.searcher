from pt_companies_search.enricher.nif_enrich import rate_limiter

def __init__(self):
    super().__init__()
        self.rate_limiter = RateLimiter()
        self.session = None
        self.last_request_time = 0

    def _wait_for_slot(self):
        """Wait for available rate limit slot"""
        if self.last_request_time:
            elapsed = time.time() - self.last_request_time
            if elapsed < 60:  # 1 minute = 60 seconds
                time.sleep(60 - elapsed)
        time.sleep(1)  # Small delay between requests
        self.last_request_time = time.time()

    def enrich_company(nif: str) -> Optional[Dict[str, Any]]:
        """Enrich company data using NIF.pt API"""
        try:
            self._wait_for_slot()
            
            url = f"https://www.nif.pt/?json=1&q={nif}&key={config.NIF_API_KEY}"
            headers = {"User-Agent": config.USER_AGENT}
            
            response = self.session.get(url, headers=headers, timeout=30)
            response.raise_for_status()
            
            data = response.json()
            
            if data.get("result") == "error":
                error_msg = data.get("message", "Unknown error")
                if "Limit" in error_msg:
                    print(f"⚠️ Rate limited: {error_msg}")
                    return None
                else:
                    print(f"❌ API Error: {error_msg}")
                    return None
            
            record = data.get("records", {}).get(str(nif), {})
            
            if not record:
                return None
            
            # Parse contacts
            contacts = record.get("contacts", {})
            
            # Parse structure (company nature + capital)
            structure = record.get("structure", {})
            
            # Parse place (location)
            place = record.get("place", {})
            
            # Parse geo (region/county/parish)
            geo = record.get("geo", {})
            
            # Get activity description
            activity_html = record.get("activity", "")
            activity_text = BeautifulSoup(activity_html, "html.parser").get_text() if activity_html else ""
            
            # Get CAE codes (may be array or string)
            cae_raw = record.get("cae", [])
            if isinstance(cae_raw, list):
                cae = ", ".join(cae_raw)
            else:
                cae = str(cae_raw)
            
            # Build enriched data
            enriched = {
                "nif": nif,
                "name": record.get("title"),
                "phone": clean_phone(contacts.get("phone")),
                "email": clean_email(contacts.get("email")),
                "website": contacts.get("website"),
                "fax": contacts.get("fax"),
                "address": place.get("address"),
                "city": place.get("city"),
                "postal_code": f"{place.get('pc4', '')}-{place.get('pc3', '')}" if place.get("pc4") else None,
                "region": geo.get("region"),
                "county": geo.get("county"),
                "parish": geo.get("parish"),
                "cae": cae,
                "activity_description": activity_text,
                "sector": get_sector(record.get("title", "")),
                "status": record.get("status"),
                "company_nature": structure.get("nature"),
                "capital": structure.get("capital"),
                "source": "nif_api",
                "source_url": f"https://www.nif.pt/{record.get('seo_url', nif)}",
                "enriched_at": datetime.now().isoformat(),
            }
            
            return enriched
        except requests.exceptions.RequestException as e:
            print(f"❌ Request error enriching {nif}: {e}")
            return None
        except Exception as e:
            print(f"❌ Unexpected error enriching {nif}: {e}")
            return None


def main():
    test_connection()
    wait_for_available_slot()
    
    # Get companies to enrich (from DB, not JSON files)
    print("📊 Loading companies to enrich...")
    companies = search_companies(source=None, limit=1000)
    
    if not companies:
        print("✅ No companies to enrich")
        return
    
    print(f"🚀 Enriching {len(companies)} companies...")
    
    rate_limiter = RateLimiter()
    
    for i, range(0, len(companies)):
        company = companies[i]
        nif = company["nif"]
        
        print(f"[{i+1}/{len(companies)}] Enriching {nif}...")
        
        enriched_data = rate_limiter.enrich_company(nif)
        
        if enriched_data:
            upsert_company(enriched_data)
            print(f"   ✅ Success")
        else:
            print(f"   ❌ Failed")
        
        if (i + 1) % 10 == 0:  # Progress update
            print(f"📊 Progress: {i+1}/{len(companies)}")
    
    print("✅ Enrichment complete!")


if __name__ == "__main__":
    main()

