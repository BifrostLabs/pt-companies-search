  docker push ghcr.io/bifrostlabs/pt-companies-searcher:v9-searcher

  kubectl apply -f /tmp/pt-companies-search/values.yaml

  helm upgrade pt-companies . -n pt-companies

  kubectl get pods -n pt-companies -l app=pt-companies-searcher
  kubectl logs job/pt-companies-searcher-test -n pt-companies --tail=50 2>&1 || true

  kubectl get cronjob -n pt-companies pt-companies-searcher
  kubectl describe cronjob pt-companies-searcher -n pt-companies
  kubectl get all -n pt-companies -l app=pt-companies-searcher

  # Test
  curl -s http://localhost:8501/health
  kubectl exec -it pt-companies-dashboard-686c699876-jg8sm -n pt-companies -- python -c "
import requests
resp = requests.get('http://localhost:8501/api/nif/searched', timeout=10)
print(f'Status: {resp.status_code}')
if resp.status_code == 200:
    data = resp.json()
